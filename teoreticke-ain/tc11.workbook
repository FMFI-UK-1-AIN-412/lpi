    {
      "id": 22,
      "type": "text",
      "data": "::h3[:cnt[b]{.a})]{.h6.float-start.my-0.me-2.fw-bold}\n\n$\\begin{aligned}\nT = \\{\n        &(\\sym{house}(\\sym{\\vx}) \\lor \\sym{tree}(\\sym{\\vy})\n         \\lor \\sym{next\\_to}(\\sym{\\vx},\\sym{\\vy})),\\\\\n        &(\\sym{tree}(\\sym{\\vy}) \\lor \\neg \\sym{next\\_to}(\n          \\sym{\\vx},\\sym{\\vy})),\\\\\n        &(\\neg \\sym{house}(\\sym{\\vx}) \\lor \\neg \\sym{tree}(\\sym{\\vy}))\n        \\}\n\\end{aligned}$\n",
      "comments": []
    },
    {
      "id": 24,
      "type": "resolutionEditor",
      "data": "{\"language\":{\"consts\":{\"input\":\"\",\"object\":[],\"error\":\"\",\"symbols\":[]},\"funs\":{\"input\":\"\",\"object\":[],\"error\":\"\",\"symbols\":[]},\"preds\":{\"input\":\"house/1, tree/1, next_to/2\",\"object\":[[\"house\",1],[\"tree\",1],[\"next_to\",2]],\"error\":\"\",\"symbols\":[{\"name\":\"house\",\"arity\":1},{\"name\":\"tree\",\"arity\":1},{\"name\":\"next_to\",\"arity\":2}]}},\"steps\":{\"order\":[0,1,2],\"allSteps\":[[0,{\"formula\":{\"input\":\"(house(x) ∨ tree(y) ∨ next_to(x,y))\",\"object\":{\"lits\":[{\"neg\":false,\"name\":\"house\",\"terms\":[{\"name\":\"x\"}]},{\"neg\":false,\"name\":\"tree\",\"terms\":[{\"name\":\"y\"}]},{\"neg\":false,\"name\":\"next_to\",\"terms\":[{\"name\":\"x\"},{\"name\":\"y\"}]}],\"litsMultiset\":null},\"error\":\"\"},\"rule\":\"Assumption\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":true}],[1,{\"formula\":{\"input\":\"(tree(y) ∨ ¬next_to(x,y))\",\"object\":{\"lits\":[{\"neg\":false,\"name\":\"tree\",\"terms\":[{\"name\":\"y\"}]},{\"neg\":true,\"name\":\"next_to\",\"terms\":[{\"name\":\"x\"},{\"name\":\"y\"}]}],\"litsMultiset\":null},\"error\":\"\"},\"rule\":\"Assumption\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":true}],[2,{\"formula\":{\"input\":\"(¬house(x) ∨ ¬tree(y))\",\"object\":{\"lits\":[{\"neg\":true,\"name\":\"house\",\"terms\":[{\"name\":\"x\"}]},{\"neg\":true,\"name\":\"tree\",\"terms\":[{\"name\":\"y\"}]}],\"litsMultiset\":null},\"error\":\"\"},\"rule\":\"Assumption\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":true}]],\"rank\":[[0,0],[1,1],[2,2]],\"id\":4},\"inputChange\":{\"originValue\":\"(house(x)∨tree(y)∨next_to(x,y))\"}}",
      "comments": []
    },
    {
      "id": 6,
      "type": "text",
      "data": ":::header\n## :icon[house-fill]{.text-primary} Cvičenie 11.:cnt[a]\n::p[Faktorizácia]{.h4}\n\n:small[:icon[source] Prednášky: :xref[15.33]{.lec label=\"def.\"}.\nZbierka: :xref[7.1.4]{.exbook label=\"úloha\"}.]\n:::\n\n:icon[tools] Sfaktorizujte klauzuly (ak je to možné):\n\n:::enum{.a}\n1. $\\lnot \\sym{lady}(\\vx) \\lor \\sym{insulted}(\\vy,\\vx)  \\lor\n           \\lnot \\sym{lady}(\\sym{Milagros})$\n2. $\\lnot \\sym{protects}(\\sym{bodyguard\\_of}(\\vx),\\vx) \\lor\n           \\lnot \\sym{protects}(\\vx,\\vy)$\n:::",
      "comments": []
    },
    {
      "id": 26,
      "type": "resolutionEditor",
      "data": "{\"language\":{\"consts\":{\"input\":\"Milagros\",\"object\":[\"Milagros\"],\"error\":\"\",\"symbols\":[\"Milagros\"]},\"funs\":{\"input\":\"bodyguard_of/1\",\"object\":[[\"bodyguard_of\",1]],\"error\":\"\",\"symbols\":[{\"name\":\"bodyguard_of\",\"arity\":1}]},\"preds\":{\"input\":\"lady/1, insulted/2, protects/2\",\"object\":[[\"lady\",1],[\"insulted\",2],[\"protects\",2]],\"error\":\"\",\"symbols\":[{\"name\":\"lady\",\"arity\":1},{\"name\":\"insulted\",\"arity\":2},{\"name\":\"protects\",\"arity\":2}]}},\"steps\":{\"order\":[0,1,2,3],\"allSteps\":[[0,{\"formula\":{\"input\":\"¬lady(x) ∨ insulted(y,x) ∨ ¬lady(Milagros)\",\"object\":{\"lits\":[{\"neg\":true,\"name\":\"lady\",\"terms\":[{\"name\":\"x\"}]},{\"neg\":false,\"name\":\"insulted\",\"terms\":[{\"name\":\"y\"},{\"name\":\"x\"}]},{\"neg\":true,\"name\":\"lady\",\"terms\":[{\"name\":\"Milagros\"}]}],\"litsMultiset\":null},\"error\":\"\"},\"rule\":\"Assumption\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":true}],[1,{\"formula\":{\"input\":\"¬lady(…) ∨ insulted(…, …)\",\"object\":{\"lits\":[{\"neg\":true,\"name\":\"lady\",\"terms\":[{\"name\":\"x\"}]},{\"neg\":false,\"name\":\"insulted\",\"terms\":[{\"name\":\"y\"},{\"name\":\"x\"}]}],\"litsMultiset\":null},\"error\":{\"message\":\"Expected term but \\\"…\\\" found.\",\"expected\":[{\"type\":\"other\",\"description\":\"term\"}],\"found\":\"…\",\"location\":{\"start\":{\"offset\":6,\"line\":1,\"column\":7},\"end\":{\"offset\":7,\"line\":1,\"column\":8}},\"name\":\"SyntaxError\"}},\"rule\":\"Factoring\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"1\",\"object\":0,\"error\":\"\"},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":false}],[2,{\"formula\":{\"input\":\"¬protects(bodyguard_of(x),x) ∨ ¬protects(x,y)\",\"object\":{\"lits\":[{\"neg\":true,\"name\":\"protects\",\"terms\":[{\"name\":\"bodyguard_of\",\"subts\":[{\"name\":\"x\"}]},{\"name\":\"x\"}]},{\"neg\":true,\"name\":\"protects\",\"terms\":[{\"name\":\"x\"},{\"name\":\"y\"}]}],\"litsMultiset\":null},\"error\":\"\"},\"rule\":\"Assumption\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":true}],[3,{\"formula\":{\"input\":\"¬protects(…, …)\",\"object\":{\"lits\":[{\"neg\":true,\"name\":\"protects\",\"terms\":[{\"name\":\"_\"},{\"name\":\"_\"}]}],\"litsMultiset\":null},\"error\":{\"message\":\"Expected term but \\\"…\\\" found.\",\"expected\":[{\"type\":\"other\",\"description\":\"term\"}],\"found\":\"…\",\"location\":{\"start\":{\"offset\":10,\"line\":1,\"column\":11},\"end\":{\"offset\":11,\"line\":1,\"column\":12}},\"name\":\"SyntaxError\"}},\"rule\":\"Factoring\",\"reference1\":{\"input\":\"\",\"error\":{\"name\":\"EmptyError\",\"message\":\"This field cannot be empty\"}},\"renaming\":{\"input\":\"\",\"error\":\"\"},\"reference2\":{\"input\":\"3\",\"object\":2,\"error\":\"\"},\"unifier\":{\"input\":\"\",\"error\":\"\"},\"valid\":false}]],\"rank\":[[0,0],[1,1],[2,2],[3,3]],\"id\":4},\"inputChange\":{\"originValue\":\"¬lady(…) ∨ insulted(…, …)\"}}",
      "comments": []
    },
    {
      "id": 7,
      "type": "text",
      "data": ":::header\n## Cvičenie 11.:cnt[a]\n\n:small[:icon[source] Prednášky: :xref[15.36]{.lec label=\"veta\"}; :xref[15.26]{.lec label=\"veta\"} a zvyšok [podkap. 15.2](https://fmfi-uk-1-ain-412.github.io/lpi/prednasky/poznamky-z-prednasok.pdf#nameddest=subsection.15.2)\nZbierka: :xref[7.3.2]{.exbook label=\"úloha\"}, :xref[7.3.1]{.exbook label=\"príklad\"}.]\n:::\n\nUvažujme nasledovné tvrdenia a ich formalizáciu\nv jazyku logiky prvého rádu _bez rovnosti_ $\\Lang$, kde\n$\\Consts = \\{\n\t\\sym{Hanka}\n\\}$,\n$\\Funcs = \\emptyset$\na $\\Preds = \\{\n\t\\sym{auticko}^1,$\n\t$\\sym{babika}^1,$\n\t$\\sym{cervene}^1,$\n\t$\\sym{dievca}^1,$\n\t$\\sym{dievcenske}^1,$\n\t$\\sym{hracka}^1,$\n\t$\\sym{hrackarstvo}^1,$\n\t$\\sym{chlapcenske}^1,$\n\t$\\sym{matfyzacka}^1,$\n\t$\\sym{P}^1,$\n\t$\\sym{saty}^1,$\n\t$\\sym{mama}^2,$\n\t$\\sym{ma}^2,$\n\t$\\sym{zakupene\\_v}^2,$\n\t$\\sym{kupi}^3\n\\}$:\n\n1. Autíčka sú chlapčenské hračky a bábiky sú dievčenské hračky.\n\n    $A_1=\\A{\\vx}(\\sym{auticko}(\\vx)\n    \\limpl (\\sym{chlapcenske}(\\vx) \\land \\sym{hracka}(\\vx))) \\land\n  \\A{\\vx}(\\sym{babika}(\\vx)\n    \\limpl (\\sym{dievcenske}(\\vx) \\land \\sym{hracka}(\\vx)))$\n\n2. Hanka je dievča, ktoré má dve autíčka.  \n\n   $A_2=(\\sym{dievca}(\\sym{Hanka}) \\land \\E{\\vx}\\E{\\vy}(\\sym{P}(\\vx) \\land \\lnot\\sym{P}(\\vy) \\land\n    \\sym{ma}(\\sym{Hanka},\\vx) \\land \\sym{auticko}(\\vx) \\land\n    \\sym{ma}(\\sym{Hanka},\\vy) \\land \\sym{auticko}(\\vy)))$\n\n3. Každá mama kúpi svojmu dieťaťu nejakú hračku.  \n\n   $A_3=\\A{\\vx}\\A{\\vy}(\\sym{mama}(\\vx,\\vy) \\limpl\n    \\E{\\vz}(\\sym{hracka}(\\vz) \\land \\sym{kupi}(\\vx,\\vy,\\vz)) )$\n\n5. Dievčatá, ktoré majú nejakú chlapčenskú hračku, sa stanú matfyzáčkami.  \n\n   $A_4= \\A{\\vx}(\\sym{dievca}(\\vx) \\limpl\n    (\\E{\\vy}(\\sym{ma}(\\vx,\\vy) \\land \\sym{hracka}(\\vy) \\land \\sym{chlapcenske}(\\vy)) \\limpl\n      \\sym{matfyzacka}(\\vx)))$\n\n::h3[:cnt[c]{.a})]{.h6.float-start.my-0.me-2.lh-base.fw-bold}\nZistite pomocou rezolvencie, či je za uvedených okolností pravda, že _ak každé dievča má aspoň jednu dievčenskú hračku, tak sa Hanka stane matfyzáčkou_.\n\nTeda, formálne, rozhodnite, či z teórie $T=\\{A_1,\\dots,A_4\\}$ vyplýva formula:\n$$\n\\begin{aligned}\nX={}&\\A{\\vx}\\big(\\sym{dievca}(\\vx) \\limpl\n    \\E{\\vy}(\\sym{ma}(\\vx,\\vy) \\land \\sym{dievcenske}(\\vy) \\land \\sym{hracka}(\\vy)) \\big)\\limpl {}\\\\\n    &\\sym{matfyzacka}(\\sym{Hanka})\n\\end{aligned}\n$$",
      "comments": []
    },
    {
      "id": 27,
      "type": "text",
      "data": "::h4[:icon[explanation] Vysvetlenie postupu]{.h5}\nZ $T$ vyplýva $X$ vtt $T' := T \\cup \\{\\lnot X\\}$ je nesplniteľná.\n\nAby sme nesplniteľnosť $T'$ dokázali rezolvenciou, musíme podľa :xref[15.36]{.lec label=\"vety\"}:\n:::enum{.i}\n1. nájsť k $T'$ ekvisplniteľnú klauzálnu teóriu $T''$,\n2. nájsť rezolvenčné zamietnutie $T''$.\n:::",
      "comments": []
    },
    {
      "id": 28,
      "type": "text",
      "data": "::h4[:icon[write] i. Úprava $T'$ na klauzálnu teóriu]{.h5}\n\n:::::aside{.note.bg-transparent.p-0}\n:icon[help]\nJeden z možných postupov úpravy $T'$ na ekvisplniteľnú klauzálnu teóriu popisuje dôkaz :xref[15.26]{.lec label=\"vety\"}.\n\n:icon[arrow-right-circle-fill]{.text-primary}\nPre každú formulu z $T'$ zdokumentujte **kľúčové medzivýsledky** jej úpravy na množinu klauzúl\n(NNF, premenovanie premenných, skolemizáciu, PNF, CNF).\nAk sa medzivýsledok nelíši od pôvodnej formuly alebo predchádzajúceho medzivýsledku, nemusíte ho písať.\n\n:icon[tools] Svoj postup si môžete overiť pomocou nového\n[kontrolóra úprav do CNF](https://killershady.github.io/bachelor-thesis-project/).\n* Predpripravený jazyk a formuly naimportujte zo súboru [tc11.4-cnf.json](https://github.com/FMFI-UK-1-AIN-412/lpi/raw/refs/heads/tc11/teoreticke-ain/tc11.4-cnf.json).\n* Úpravy exportujte a odložte si ich.\n:::::\n\n::h5[$\\boldsymbol{A_1}$]{.h6}\n* NNF: $…$\n* Premenovanie premenných: $…$\n* …\n\n::h5[$\\boldsymbol{A_2}$]{.h6}\n* …\n\n::h5[$\\boldsymbol{A_3}$]{.h6}\n* …\n\n::h5[$\\boldsymbol{A_4}$]{.h6}\n* …\n\n::h5[$\\boldsymbol{\\lnot X}$]{.h6}\n* …\n",
      "comments": []
    },
    {
      "id": 29,
      "type": "text",
      "data": "::h4[:icon[tools] ii. Nájdenie zamietnutia]{.h5}\nPomocou rezolvenčného editora nájdeme zamietnutie klauzálnej teórie,\nktorú ste vytvorili v predchádzajúcom kroku.\nV editore uveďte celú výslednú klauzálnu teóriu $T''$\na do jazyka doplňte skolemovské symboly.",
      "comments": []
    },
    {
      "id": 18,
      "type": "resolutionEditor",
      "data": "{\"language\":{\"consts\":{\"input\":\"Hanka\",\"object\":[\"Hanka\"],\"error\":\"\",\"symbols\":[\"Hanka\"]},\"funs\":{\"input\":\"\",\"object\":[],\"error\":\"\",\"symbols\":[]},\"preds\":{\"input\":\"auticko/1, babika/1, cervene/1, dievca/1, dievcenske/1, hracka/1, chlapcenske/1, ma/2, matfyzacka/1, P/1, saty/1\",\"object\":[[\"auticko\",1],[\"babika\",1],[\"cervene\",1],[\"dievca\",1],[\"dievcenske\",1],[\"hracka\",1],[\"chlapcenske\",1],[\"ma\",2],[\"matfyzacka\",1],[\"P\",1],[\"saty\",1]],\"error\":\"\",\"symbols\":[{\"name\":\"auticko\",\"arity\":1},{\"name\":\"babika\",\"arity\":1},{\"name\":\"cervene\",\"arity\":1},{\"name\":\"dievca\",\"arity\":1},{\"name\":\"dievcenske\",\"arity\":1},{\"name\":\"hracka\",\"arity\":1},{\"name\":\"chlapcenske\",\"arity\":1},{\"name\":\"ma\",\"arity\":2},{\"name\":\"matfyzacka\",\"arity\":1},{\"name\":\"P\",\"arity\":1},{\"name\":\"saty\",\"arity\":1}]}},\"steps\":{\"order\":[],\"allSteps\":[],\"rank\":[],\"id\":8},\"inputChange\":{\"originValue\":\"auticko /1, babika/1, cervene/1, dievcenske/1, hracka/1, chlapcenske/1, matfyzacka/1, P/1, saty/1, ma/2, dievca/1\"}}",
      "comments": []
    },
    {
      "id": 19,
      "type": "text",
      "data": "::h4[:icon[write] iii. Záver a interpretácia]{.h5}\n\n:small[Našli ste zamietnutie $T''$? Akú vlastnosť má potom $T''$ a $T'$ a prečo?\nAký záver z toho vyvodzujete pre formálnu a neformálnu otázku zadanú v časti **a)**?]\n\n…",
      "comments": []
    },
    {
      "id": 20,
      "type": "text",
      "data": "::h3[:icon[homework] :icon[write] :cnt[c]{.a})]{.h6.float-start.my-0.me-2.lh-base.fw-bold}\nPreveďte nasledujúce formuly v jazyku $\\Lang$ do ekvisplniteľnej klauzálnej teórie\npodobne ako v ii. kroku časti a):\n\n5. Každá hračka bola zakúpená v hračkárstve.  \n\n   $A_5=\\A{\\vx}(\\sym{hracka}(\\vx) \\limpl\n    \\E{\\vy}\\,(\\sym{zakupene\\_v}(\\vx,\\vy) \\land \\sym{hrackarstvo}(\\vy)) )$  \n\n6. Hanka má bábiku, ktorá má červené šaty.  \n\n   $A_6=\n   \\E{\\vx}(\\sym{ma}(\\sym{Hanka},\\vx) \\land \\sym{babika}(\\vx) \\land\n    \\E{\\vy}(\\sym{ma}(\\vx,\\vy) \\land \\sym{cervene}(\\vy) \\land \\sym{saty}(\\vy)))$",
      "comments": []
    }
  ],
  "settings": {
    "katexMacros": "\\newcommand{\\DeclareMathOperator}[2]{\\newcommand{#1}{\\mathop{\\mathrm{#2}}}}\n\n%% General math\n\n% Domain and range\n\\DeclareMathOperator{\\dom}{dom}\n\\DeclareMathOperator{\\rng}{rng}\n\n% Powerset\n\\newcommand\\powerset[1]{\\mathcal{P}(#1)}\n\n% Cardinality\n\\newcommand{\\card}[1]{\\lvert#1\\rvert}\n\n% Numbers\n\\newcommand{\\Nat}{\\mathbb{N}}\n\n% Operations\n\\newcommand{\\TIMES}{\\cdot}\n\n\n% Meta syntax %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n\n\\DeclareMathOperator{\\arity}{ar}\n\\newcommand{\\Lang}{\\mathcal{L}}\n\\newcommand{\\Vars}{\\mathcal{V}_{\\Lang}}\n\\newcommand{\\Consts}{\\mathcal{C}_{\\Lang}}\n\\newcommand{\\Preds}{\\mathcal{P}_{\\Lang}}\n\\newcommand{\\Funcs}{\\mathcal{F}_{\\Lang}}\n\\newcommand{\\Terms}{\\mathcal{T}_{\\Lang}}\n\\newcommand{\\Atoms}{\\mathcal{A}_{\\Lang}}\n\\newcommand{\\Forms}{\\mathcal{E}_{\\Lang}}\n\\newcommand{\\PAtoms}{\\mathcal{PA}_{\\Lang}}\n\\newcommand{\\PForms}{\\mathcal{PE}_{\\Lang}}\n\n% Equality axioms\n\\newcommand{\\Eq}{\\mathrm{Eq}}\n\n% Syntactic transformation\n\\newcommand{\\transform}{\\rightsquigarrow}\n\n% Various syntactic functions\n\\DeclareMathOperator{\\vars}{vars}\n\\DeclareMathOperator{\\atoms}{atoms}\n\\DeclareMathOperator{\\acnt}{acnt}\n\\DeclareMathOperator{\\termVars}{termVars}\n\\DeclareMathOperator{\\free}{free}\n\\DeclareMathOperator{\\ground}{ground}\n\\DeclareMathOperator{\\mgu}{mgu}\n\\DeclareMathOperator{\\vcount}{vcount}\n\\DeclareMathOperator{\\acount}{acount}\n\\DeclareMathOperator{\\ccount}{ccount}\n\\DeclareMathOperator{\\pcount}{pcount}\n\\DeclareMathOperator{\\ncount}{ncount}\n\\DeclareMathOperator{\\cjcount}{cjcount}\n\\DeclareMathOperator{\\bccount}{bccount}\n\\DeclareMathOperator{\\lpcount}{lpcount}\n\\DeclareMathOperator{\\rpcount}{rpcount}\n\\DeclareMathOperator{\\subfs}{subfs}\n\\DeclareMathOperator{\\cons}{cons}\n\\DeclareMathOperator{\\nnf}{nnf}\n\n\n% Concrete syntax %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%