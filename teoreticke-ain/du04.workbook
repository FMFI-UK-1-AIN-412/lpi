          },
          "comments": []
        },
        {
          "id": 56,
          "type": "context/addAxioms",
          "data": [
            {
              "name": "A_1",
              "formula": "∀x(sock(x)→(worn_out(x)→∃y(hole(y)∧has(x,y))))"
            },
            {
              "name": "A_2",
              "formula": "∀x((sock(x)∧¬worn_out(x))→¬old(x))"
            },
            {
              "name": "A_3",
              "formula": "∀x(¬old(x)↔new(x))"
            }
          ],
          "contextExtension": {
            "constants": [],
            "predicates": [],
            "functions": [],
            "formulas": [],
            "axioms": [
              {
                "name": "A_1",
                "formula": "∀x (sock(x) → (worn_out(x) → ∃y (hole(y) ∧ has(x, y))))"
              },
              {
                "name": "A_2",
                "formula": "∀x ((sock(x) ∧ ¬worn_out(x)) → ¬old(x))"
              },
              {
